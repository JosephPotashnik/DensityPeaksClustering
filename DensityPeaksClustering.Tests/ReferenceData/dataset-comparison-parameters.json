{
  "source": {
    "name": "SIPU / University of Eastern Finland clustering datasets",
    "url": "https://cs.uef.fi/sipu/datasets/",
    "note": "Shape-set text files contain x, y, and ground-truth label as the third column."
  },
  "distanceMetric": "Euclidean",
  "currentGoldenParameters": {
    "knn": {
      "k": 10,
      "tuningType": "FineTuning"
    },
    "multiManifold": {
      "k": 10,
      "m": 10,
      "tuningType": "FineTuning"
    },
    "densityPeaks": {
      "cutoffDistance": 2.0,
      "centerSelection": "FineTuning",
      "useHaloProcessing": true
    }
  },
  "recommendedExternalDpcComparisonParameters": {
    "density": "count of points with distance < dc",
    "centerSelection": "TopKGamma",
    "gamma": "rho * delta",
    "assignment": "nearest neighbor with higher density",
    "haloProcessing": "record whether enabled; compare both enabled and disabled if the external implementation supports it",
    "additionalParametersRequired": [
      "dc",
      "k",
      "distanceMetric",
      "densityDefinition",
      "centerSelection",
      "haloProcessing",
      "tieHandling"
    ]
  },
  "datasets": [
